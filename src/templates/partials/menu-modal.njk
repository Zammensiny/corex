<div class="menu-modal" id="menu-modal" aria-hidden="true" data-menu-modal data-cms-block="menu-modal">
  <div class="menu-modal__panel" role="dialog" aria-modal="true" aria-label="Меню сайта">
    <div class="container menu-modal__container">
      <div class="menu-modal__top">
        <a class="menu-modal__logo site-logo" href="index.html" aria-label="На главную" data-menu-modal-link data-cms-field="logo">
          <img class="site-logo__image" src="assets/logo.svg" width="219" height="60" alt="Корекс системы">
        </a>

        <button class="menu-modal__close" type="button" aria-label="Закрыть меню" data-menu-modal-close>
          <span aria-hidden="true"></span>
        </button>
      </div>

      <div class="menu-modal__content">
        <div class="menu-modal__left">
          <nav class="menu-modal__nav" aria-label="Полное меню" data-cms-field="menu">
            <a{% if pageId == "about" %} class="is-current"{% endif %} href="about.html" data-menu-modal-link>О нас</a>
            <a{% if pageId == "ai" %} class="is-current"{% endif %} href="ai.html" data-menu-modal-link>ИИ-инструменты</a>
          </nav>

          <div class="menu-modal__contacts" data-cms-field="contacts">
            <div class="menu-modal__mail">
              <a href="mailto:hello@corex.systems">hello@corex.systems</a>
              <button class="menu-modal__copy" type="button" aria-label="Скопировать почту" data-copy-email="hello@corex.systems">
                <span></span>
              </button>
            </div>

            <a class="menu-modal__phone" href="tel:+74951203802">+7 495 120 38 02</a>
          </div>
        </div>

        <div class="menu-modal__visual" aria-hidden="true">
          <div class="menu-orbit">
            <span class="menu-orbit__ring"></span>
            <img class="menu-orbit__center" src="assets/logo.svg" width="219" height="60" alt="">

            <span class="menu-orbit__card menu-orbit__card--gear">
              <img src="assets/img/hero-card-gear.png" alt="">
            </span>
            <span class="menu-orbit__card menu-orbit__card--mvp">
              <img src="assets/img/hero-card-mvp.png" alt="">
            </span>
            <span class="menu-orbit__card menu-orbit__card--html">
              <img src="assets/img/hero-card-html.png" alt="">
            </span>
          </div>

          <ul class="menu-modal__socials" aria-label="Социальные сети">
            <li><a href="#" aria-label="Telegram"><img src="assets/icons/social-telegram.svg" width="25" height="25" alt=""></a></li>
            <li><a href="#" aria-label="WhatsApp"><img src="assets/icons/social-whatsapp.svg" width="22" height="22" alt=""></a></li>
            <li><a href="#" aria-label="VK"><img src="assets/icons/social-vk.svg" width="22" height="22" alt=""></a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
