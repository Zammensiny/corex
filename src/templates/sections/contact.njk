<section class="contact" id="brief" data-cms-block="contact">
  <div class="container contact__container">
    <div class="contact-card">
      <div class="contact-card__content">
        <span class="contact-card__icon" aria-hidden="true">
          <img src="assets/icons/problem-file.svg" width="28" height="28" alt="">
        </span>

        <h2 class="contact-card__title" data-cms-field="title">Опишите задачу —<br>мы скажем, как её решить</h2>

        <div class="contact-card__contacts" data-cms-field="contacts">
          <a class="contact-link contact-link--email" href="mailto:pochta@gmail.com">Почта@gmail.com</a>
          <button class="contact-copy" type="button" data-copy-email="pochta@gmail.com" aria-label="Скопировать почту">
            <span aria-hidden="true"></span>
          </button>
          <a class="contact-link contact-link--phone" href="tel:+74951203802">+7 495 120 38 02</a>
        </div>
      </div>

      <form class="contact-form" action="#" method="post" data-cms-field="form">
        <label class="contact-form__field">
          <span class="visually-hidden">Имя</span>
          <input type="text" name="name" placeholder="Имя" autocomplete="name">
        </label>

        <label class="contact-form__field">
          <span class="visually-hidden">Номер телефона</span>
          <input type="tel" name="phone" placeholder="Номер телефона" autocomplete="tel">
        </label>

        <button class="button button--primary contact-form__submit" type="submit">Обсудить задачу</button>
      </form>

      <div class="contact-card__socials" aria-label="Социальные сети" data-cms-field="socials">
        <a href="#" aria-label="Telegram"><span>tg</span></a>
        <a href="#" aria-label="WhatsApp"><span>wa</span></a>
        <a href="#" aria-label="VK"><span>vk</span></a>
      </div>
    </div>
  </div>
</section>
