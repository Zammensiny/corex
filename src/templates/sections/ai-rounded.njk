<section class="ai-rounded" data-cms-block="ai-rounded">
  <div class="container ai-rounded__container">
    <section class="ai-implementation" data-cms-field="implementation">
      <div class="ai-implementation__head">
        <h2 class="ai-implementation__title">Как мы внедряем<br>ИИ-инструменты в ваш бизнес?</h2>
        <p class="ai-implementation__lead">Отработанная методика, чек-лист проверок<br>на каждом этапе, строгая отчетность.</p>
      </div>

      <div class="ai-implementation__cards">
        <article class="ai-step-card ai-step-card--analysis">
          <h3>Анализируем<br>ваш бизнес</h3>
          <div class="ai-step-card__visual ai-step-card__visual--analysis" aria-hidden="true">
            <span class="ai-step-card__document ai-step-card__document--one"></span>
            <span class="ai-step-card__document ai-step-card__document--two"></span>
            <span class="ai-step-card__document ai-step-card__document--three"></span>
            <span class="ai-step-card__search"><img src="assets/icons/problem-chart-line.svg" width="16" height="16" alt=""></span>
          </div>
        </article>

        <article class="ai-step-card ai-step-card--losses">
          <h3>Находим точки<br>потерь в бизнесе</h3>
          <div class="ai-step-card__visual ai-step-card__visual--radar" aria-hidden="true">
            <span class="ai-radar__ring ai-radar__ring--one"></span>
            <span class="ai-radar__ring ai-radar__ring--two"></span>
            <span class="ai-radar__center"><img src="assets/icons/problem-down.svg" width="15" height="15" alt=""></span>
            <span class="ai-radar__dot ai-radar__dot--one"></span>
            <span class="ai-radar__dot ai-radar__dot--two"></span>
            <span class="ai-radar__dot ai-radar__dot--three"></span>
            <span class="ai-radar__dot ai-radar__dot--four"></span>
          </div>
        </article>

        <article class="ai-step-card ai-step-card--solution">
          <h3>Проектируем<br>ИИ-решение</h3>
          <div class="ai-step-card__visual ai-step-card__visual--solution" aria-hidden="true">
            <span class="ai-tool-card"><img src="assets/icons/hero-brain.svg" width="24" height="24" alt=""></span>
            <span class="ai-tool-card ai-tool-card--large"><img src="assets/icons/hero-rocket.svg" width="26" height="26" alt=""></span>
            <span class="ai-tool-card"><img src="assets/icons/fit-chart-area.svg" width="24" height="24" alt=""></span>
          </div>
        </article>

        <article class="ai-step-card ai-step-card--launch">
          <h3>Внедряем и доводим<br>до результата</h3>
          <div class="ai-step-card__visual ai-step-card__visual--launch" aria-hidden="true">
            <span class="ai-tech-card"><img src="assets/icons/fit-file.svg" width="20" height="20" alt=""><small>HTML</small></span>
            <span class="ai-tech-card"><img src="assets/icons/hero-gear.svg" width="21" height="21" alt=""><small>3D</small></span>
            <span class="ai-tech-card"><img src="assets/icons/icon-gear.svg" width="20" height="20" alt=""><small>JS</small></span>
          </div>
        </article>
      </div>

      <div class="ai-implementation__actions">
        <button class="button button--primary" type="button" data-request-modal-open data-request-type="brief">Обсудить задачу</button>
        <button class="button button--light" type="button" data-request-modal-open data-request-type="audit">Получить аудит</button>
      </div>
    </section>
  </div>

  {% include "sections/cases.njk" %}
</section>
