<section class="company-hero" id="about" data-cms-block="company-hero">
  <div class="container company-hero__container">
    <div class="company-hero__content">
      <h1 class="company-hero__title" data-cms-field="title">Мы не внедряем инструменты.<br>Мы собираем работающие системы</h1>
      <p class="company-hero__lead" data-cms-field="subtitle">Разрабатываем и внедряем IT и AI–решения,<br>которые наводят порядок в процессах и дают бизнесу контроль</p>

      <div class="company-hero__actions" data-cms-field="buttons">
        <button class="button button--primary" type="button" data-request-modal-open data-request-type="brief">Обсудить задачу</button>
        <button class="button button--light" type="button" data-request-modal-open data-request-type="audit">Получить аудит</button>
      </div>
    </div>

    <div class="company-scheme" aria-label="Схема работающей системы" data-cms-field="scheme">
      <span class="company-scheme__line company-scheme__line--left-a"></span>
      <span class="company-scheme__line company-scheme__line--left-b"></span>

      <div class="company-inputs" aria-label="Исходные инструменты">
        <article class="company-input company-input--html">
          <img src="assets/img/hero-card-html.png" width="105" height="105" alt="">
        </article>
        <article class="company-input company-input--mvp">
          <img src="assets/img/hero-card-mvp.png" width="105" height="105" alt="">
        </article>
        <article class="company-input company-input--js">
          <img src="assets/img/hero-card-gear.png" width="105" height="105" alt="">
        </article>
      </div>

      <article class="company-flow-card" aria-label="Процесс и документация">
        <div class="company-flow-card__map">
          <span></span><span></span><span></span><span></span>
        </div>
        <div class="company-flow-card__text">
          <span></span><span></span><span></span><span></span>
        </div>
      </article>

      <article class="company-stack" aria-label="Системный контур">
        <span class="company-stack__cell"><img src="assets/icons/hero-user.svg" width="28" height="28" alt=""></span>
        <span class="company-stack__cell company-stack__cell--active"><img src="assets/icons/hero-molecul.svg" width="30" height="30" alt=""></span>
        <span class="company-stack__cell"><img src="assets/icons/hero-user.svg" width="28" height="28" alt=""></span>
      </article>

      <div class="company-dashboard" aria-label="Отчётность и контроль">
        <article class="company-dashboard__icons">
          <span><img src="assets/icons/problem-users.svg" width="20" height="20" alt=""></span>
          <span><img src="assets/icons/hero-check.svg" width="20" height="20" alt=""></span>
          <span><img src="assets/icons/fire.svg" width="20" height="20" alt=""></span>
        </article>
        <article class="company-dashboard__chart" aria-label="График">
          <span style="--h: 62%"></span>
          <span style="--h: 78%"></span>
          <span style="--h: 88%"></span>
          <span style="--h: 70%"></span>
          <span style="--h: 58%"></span>
          <span style="--h: 86%"></span>
          <span style="--h: 64%"></span>
          <span style="--h: 55%"></span>
          <span style="--h: 69%"></span>
          <span style="--h: 80%"></span>
        </article>
      </div>
    </div>
  </div>
</section>
