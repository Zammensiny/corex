<section class="fit" id="fit" data-cms-block="fit">
  <div class="fit__stage" aria-hidden="true">
    <span class="fit-ray fit-ray--top"></span>
    <span class="fit-ray fit-ray--left"></span>
    <span class="fit-ray fit-ray--left-bottom"></span>
    <span class="fit-ray fit-ray--right"></span>
  </div>

  <div class="container fit__container">
    <div class="fit__center" data-cms-field="center">
      <h2 class="fit__title">Не просто сайт<br>— SEO, адаптация<br>и сопровождение<br>под ключ.</h2>
      <p class="fit__lead">Мы не для всех. И это нормально.<br>К нам приходят, когда:</p>
    </div>

    <div class="fit-point fit-point--contractor" data-cms-field="reason">
      <p class="fit-point__text">Подрядчик<br>не довёл проект</p>
      <span class="fit-point__icon"><img src="assets/icons/fit-pen.svg" alt="" loading="lazy"></span>
    </div>

    <div class="fit-point fit-point--result" data-cms-field="reason">
      <p class="fit-point__text">Внедрение<br>не дало результата</p>
      <span class="fit-point__icon"><img src="assets/icons/fit-chart-area.svg" alt="" loading="lazy"></span>
    </div>

    <div class="fit-point fit-point--task" data-cms-field="reason">
      <span class="fit-point__icon"><img src="assets/icons/problem-file.svg" alt="" loading="lazy"></span>
      <p class="fit-point__text">Задача<br>нестандартная</p>
    </div>

    <div class="fit-point fit-point--growth" data-cms-field="reason">
      <span class="fit-point__icon"><img src="assets/icons/fit-bomb.svg" alt="" loading="lazy"></span>
      <p class="fit-point__text">Процессы<br>разваливаются<br>при росте</p>
    </div>

    <div class="fit-trust" data-cms-field="trust">
      <p class="fit-trust__label">Нам доверяют:</p>
      <ul class="fit-trust__list">
        <li><img class="fit-trust__logo fit-trust__logo--proline" src="assets/img/trust-proline.png" width="120" height="49" alt="Proline" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--atmos" src="assets/img/trust-atmos.png" width="120" height="120" alt="ATMOC" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--marcy" src="assets/img/trust-marcy.png" width="214" height="120" alt="Marcy" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--meilin" src="assets/img/trust-meilin.png" width="120" height="120" alt="Meilin Auto" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--crm" src="assets/img/trust-crm.png" width="206" height="84" alt="CRM" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--innovations" src="assets/img/trust-innovations.png" width="272" height="68" alt="С Инновации" loading="lazy"></li>
        <li><img class="fit-trust__logo fit-trust__logo--technonicol" src="assets/img/trust-technonicol.png" width="300" height="51" alt="Технониколь" loading="lazy"></li>
      </ul>
    </div>
  </div>
</section>
